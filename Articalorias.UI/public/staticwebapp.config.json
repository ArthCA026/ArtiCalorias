{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "*.{png,jpg,gif,css,js,mjs,ico,svg,woff,woff2,json,txt,map,webp,avif,ttf,eot,otf}"
    ]
  },
  "mimeTypes": {
    ".js": "application/javascript",
    ".mjs": "application/javascript"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY"
  }
}
